# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables
.env

# Keep documents directory but not contents
data/documents/*
!data/documents/.gitkeep

# Keep ads directory but not contents
data/ads/*
!data/ads/.gitkeep

# Keep events directory but not contents
data/events/*
!data/events/.gitkeep
data/
*.db
