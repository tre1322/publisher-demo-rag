# ════════════════════════════════════════════════════════════════════
#  Amplafai — environment surface
#  Web service (src/chatbot.py) AND voice worker
#  (python -m src.modules.pmc.voice_agent start) read the SAME vars.
#  Set these per-service in the Railway dashboard, not in a committed file.
# ════════════════════════════════════════════════════════════════════

# ── Core ────────────────────────────────────────────────────────────
# Anthropic powers PMC synthesis AND the voice interviewer's LLM.
ANTHROPIC_API_KEY=sk-ant-replace_me

# Railway injects PORT automatically; the app falls back to 8080 locally.
# Do NOT hard-set this on Railway.
# PORT=8080

# ── Auth & public URLs (PROD-CRITICAL — wrong values fail silently) ──
# Sign business_users session cookies. MUST be a random 32+ char string
# in production (insecure default logs a warning and is unsafe).
BUSINESS_SESSION_SECRET=dev-secret-change-me

# Admin console is HTTP Basic: username is always "admin", password is
# this var. Default is literally "admin" — MUST be overridden in prod.
ADMIN_PASSWORD=change-me-strong

# Where Stripe Checkout redirects back after pay/cancel. MUST be the real
# public origin in prod, e.g. https://app.amplafai.com (NO trailing path).
BASE_URL=http://localhost:8080

# Where the voice WORKER POSTs the finished transcript back to the WEB
# app. Must be reachable from the worker service. In prod set to the web
# app's public origin (https://app.amplafai.com) or, better, the Railway
# private URL of the web service. Callback is HMAC-signed (90-min TTL).
PMC_VOICE_CALLBACK_BASE_URL=http://localhost:8080

# ── Stripe billing (W1) ─────────────────────────────────────────────
# STRIPE_API_KEY: sk_test_* (pilot) or sk_live_* (real charges).
# STRIPE_WEBHOOK_SECRET: whsec_* — for the PROD webhook endpoint created
#   in the Stripe dashboard (https://app.amplafai.com/webhooks/stripe),
#   NOT the `stripe listen` dev secret.
# STRIPE_PRICE_*: recurring Price IDs. Each Price's metadata.tier MUST be
#   exactly starter / growth / concierge — the webhook maps back by it.
STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_GROWTH=price_replace_me
STRIPE_PRICE_CONCIERGE=price_replace_me

# ── Voice interview (W2.2) ──────────────────────────────────────────
# LiveKit Cloud — https://livekit.io/cloud. Free tier covers the pilot.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxx

# Deepgram (Nova-3 STT) — https://console.deepgram.com
DEEPGRAM_API_KEY=dgxxxxxxxxxxxxx

# Cartesia (Sonic-2 TTS) — https://play.cartesia.ai
# CARTESIA_VOICE_ID has a warm-personal default; override to A/B voices.
CARTESIA_API_KEY=cartxxxxxxxxxxxxx
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# Agent dispatch name. The web /voice/start route dispatches by this
# name; the worker registers with it. MUST be identical on BOTH the web
# service and the voice-worker service.
PMC_AGENT_NAME=amplafai-pmc-interviewer

# Interview pacing (seconds). 1800 = 30-min target; pacing rule fires at
# 75%. Pause cap auto-ends a forgotten pause after this many seconds.
PMC_INTERVIEW_TARGET_SECONDS=1800
PMC_INTERVIEW_PAUSE_CAP_SECONDS=600

# ── Recording → DigitalOcean Spaces (S3-compatible) ─────────────────
# LiveKit Egress writes the call recording here. Put a 30-day lifecycle
# rule on the bucket (scripts/setup_spaces_lifecycle.py does this once).
# Set PMC_VOICE_RECORDING_ENABLED=false to skip recording entirely.
PMC_VOICE_RECORDING_ENABLED=true
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY=DOxxxxxxxxxxxxx
SPACES_SECRET_KEY=xxxxxxxxxxxxx
SPACES_BUCKET=amplafai-pmc-recordings
SPACES_REGION=us-east-1
