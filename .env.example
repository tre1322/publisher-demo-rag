# Required
ANTHROPIC_API_KEY=your_api_key_here

# Required for Vision pipeline (GPT-5.4)
OPENAI_API_KEY=your_openai_key_here

# Vision pipeline settings
VISION_PROVIDER=openai
VISION_MODEL=gpt-5.4

# Optional - defaults shown
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.3
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma_db
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_TOKENS=8000

# Amplora billing (W1) — Stripe processor
# STRIPE_API_KEY: secret key sk_test_* (dev) or sk_live_* (prod)
# STRIPE_WEBHOOK_SECRET: whsec_* from `stripe listen` (dev) or dashboard (prod)
# STRIPE_PRICE_*: per-tier recurring Price IDs from Stripe dashboard.
#   Each Price MUST have metadata.tier set to the matching tier string —
#   the webhook reads it to map back to local tier names.
STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_GROWTH=price_replace_me
STRIPE_PRICE_CONCIERGE=price_replace_me

# Sign business_users session cookies. MUST be set in production.
BUSINESS_SESSION_SECRET=dev-secret-change-me
