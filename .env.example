# Required
ANTHROPIC_API_KEY=your_api_key_here

# Required for Vision pipeline (GPT-5.4)
OPENAI_API_KEY=your_openai_key_here

# Vision pipeline settings
VISION_PROVIDER=openai
VISION_MODEL=gpt-5.4

# Optional - defaults shown
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.3
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma_db
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_TOKENS=8000

# Amplora billing (W1) — Stripe processor
# STRIPE_API_KEY: secret key sk_test_* (dev) or sk_live_* (prod)
# STRIPE_WEBHOOK_SECRET: whsec_* from `stripe listen` (dev) or dashboard (prod)
# STRIPE_PRICE_*: per-tier recurring Price IDs from Stripe dashboard.
#   Each Price MUST have metadata.tier set to the matching tier string —
#   the webhook reads it to map back to local tier names.
STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_GROWTH=price_replace_me
STRIPE_PRICE_CONCIERGE=price_replace_me

# Sign business_users session cookies. MUST be set in production.
BUSINESS_SESSION_SECRET=dev-secret-change-me

# ── Amplora voice interview (W2.2) ────────────────────────────────────
# LiveKit Cloud — sign up at https://livekit.io/cloud. Free tier covers
# the Q3 pilot (10k participant-min/mo, ~5k 35-min interviews).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxx

# Deepgram — https://console.deepgram.com (Nova-3 streaming). Pay-as-you-go.
DEEPGRAM_API_KEY=dgxxxxxxxxxxxxx

# Cartesia — https://play.cartesia.ai (Sonic-2 TTS). Pay-as-you-go.
# CARTESIA_VOICE_ID defaults to a warm-personal baseline; A/B during Day 2 testing.
CARTESIA_API_KEY=cartxxxxxxxxxxxxx
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# Interview pacing (seconds). 1800 = 30 min target; agent's "wrap up" rule
# fires at 75% of this. Hard ceiling at 60 min via interview_script.py.
PMC_INTERVIEW_TARGET_SECONDS=1800

# Agent dispatch name (must match the worker process registration).
PMC_AGENT_NAME=amplora-pmc-interviewer

# Recording → DigitalOcean Spaces. Bucket should have a 30-day lifecycle rule.
PMC_VOICE_RECORDING_ENABLED=true
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_ACCESS_KEY=DOxxxxxxxxxxxxx
SPACES_SECRET_KEY=xxxxxxxxxxxxx
SPACES_BUCKET=amplora-pmc-recordings
SPACES_REGION=us-east-1
